diff --git a/lib/rpi_cmdlinetxt.c b/lib/rpi_cmdlinetxt.c
new file mode 100644
index 00000000..d90ed40e
--- /dev/null
+++ b/lib/rpi_cmdlinetxt.c
@@ -0,0 +1,59 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Raspberry Pi cmdline.txt parser
+ *
+ * Matches VideoCore GPU bootloader behaviour: reads only the first
+ * line of cmdline.txt, passes bytes through as-is (no comment
+ * stripping, no whitespace normalisation), and falls back to a
+ * caller-supplied default if the first line is empty or
+ * whitespace-only. See include/rpi_cmdlinetxt.h for details.
+ */
+
+#include <env.h>
+#include <linux/ctype.h>
+#include <linux/errno.h>
+#include <linux/types.h>
+#include <malloc.h>
+#include <rpi_cmdlinetxt.h>
+#include <stdbool.h>
+#include <string.h>
+
+int rpi_cmdlinetxt_parse(const char *buf, size_t size)
+{
+	size_t i;
+	size_t line_len;
+	bool has_nonspace = false;
+	char *line;
+	int ret;
+
+	if (!buf)
+		return -EINVAL;
+
+	/* End of first line: position of first LF, or end of buffer. */
+	for (i = 0; i < size && buf[i] != '\n'; i++) {
+		if (!isspace((unsigned char)buf[i]))
+			has_nonspace = true;
+	}
+	line_len = i;
+
+	/*
+	 * Empty or whitespace-only first line -> delete bootargs so the
+	 * caller's default takes effect. This mirrors VideoCore firmware,
+	 * which substitutes its built-in default cmdline in this case.
+	 */
+	if (!has_nonspace)
+		return env_set("bootargs", NULL);
+
+	/* Copy the first line verbatim and NUL-terminate for env_set. */
+	line = malloc(line_len + 1);
+	if (!line)
+		return -ENOMEM;
+
+	memcpy(line, buf, line_len);
+	line[line_len] = '\0';
+
+	ret = env_set("bootargs", line);
+	free(line);
+
+	return ret;
+}
