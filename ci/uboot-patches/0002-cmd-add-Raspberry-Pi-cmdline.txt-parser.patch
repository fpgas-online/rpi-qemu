diff --git a/test/cmd/cmdlinetxt.c b/test/cmd/cmdlinetxt.c
new file mode 100644
index 00000000..6e87f022
--- /dev/null
+++ b/test/cmd/cmdlinetxt.c
@@ -0,0 +1,196 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Tests for cmdlinetxt command (Raspberry Pi cmdline.txt parser).
+ *
+ * These tests verify that the parser reproduces VideoCore GPU
+ * bootloader semantics: first line only, pass-through verbatim,
+ * empty/whitespace-only line clears bootargs so defaults apply.
+ */
+
+#include <command.h>
+#include <env.h>
+#include <mapmem.h>
+#include <rpi_cmdlinetxt.h>
+#include <test/test.h>
+#include <test/ut.h>
+
+#define CMDLINETXT_TEST(_name, _flags)	UNIT_TEST(_name, _flags, cmdlinetxt)
+
+/*
+ * Helper: stage @content at a fixed sandbox address and run
+ * "cmdlinetxt <addr> <size>". Always clears bootargs first so
+ * tests see the parser's effect, not any stale value.
+ */
+static void cmdlinetxt_run(const char *content, size_t size)
+{
+	u8 *buf = map_sysmem(0x1000, 4096);
+	char cmd[64];
+
+	memcpy(buf, content, size);
+	env_set("bootargs", NULL);
+	snprintf(cmd, sizeof(cmd), "cmdlinetxt 1000 %lx",
+		 (unsigned long)size);
+	run_command(cmd, 0);
+	unmap_sysmem(buf);
+}
+
+/* Single line, no trailing LF: whole buffer becomes bootargs. */
+static int cmdlinetxt_test_single_line_no_lf(struct unit_test_state *uts)
+{
+	const char *content = "root=/dev/nfs rw console=ttyAMA0";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("root=/dev/nfs rw console=ttyAMA0",
+			env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_single_line_no_lf, 0);
+
+/* Single line with trailing LF: LF is stripped but nothing else. */
+static int cmdlinetxt_test_single_line_trailing_lf(struct unit_test_state *uts)
+{
+	const char *content = "root=/dev/nfs rw console=ttyAMA0\n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("root=/dev/nfs rw console=ttyAMA0",
+			env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_single_line_trailing_lf, 0);
+
+/*
+ * Two lines: VideoCore firmware uses line 1 only; line 2 is
+ * discarded even if it looks like a kernel command line.
+ */
+static int cmdlinetxt_test_two_lines_uses_first(struct unit_test_state *uts)
+{
+	const char *content =
+		"root=/dev/nfs\nignored=second rootwait=no\n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("root=/dev/nfs", env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_two_lines_uses_first, 0);
+
+/*
+ * Leading '#' on line 1: NOT a comment in VideoCore. The '#' and
+ * the rest of the line pass through as literal bootargs. This is
+ * the VideoCore-exact behaviour (bugs for the user, but matches).
+ */
+static int cmdlinetxt_test_hash_is_literal(struct unit_test_state *uts)
+{
+	const char *content = "# this looks like a comment\n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("# this looks like a comment",
+			env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_hash_is_literal, 0);
+
+/*
+ * Empty first line (just '\n') -> bootargs is deleted so the
+ * caller's default can kick in. Matches VideoCore "empty cmdline.txt
+ * falls back to built-in defaults".
+ */
+static int cmdlinetxt_test_empty_first_line(struct unit_test_state *uts)
+{
+	const char *content = "\nroot=/dev/second-line\n";
+
+	env_set("bootargs", "stale");
+	cmdlinetxt_run(content, strlen(content));
+	ut_assertnull(env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_empty_first_line, 0);
+
+/* Whitespace-only first line also clears bootargs. */
+static int cmdlinetxt_test_whitespace_only_line(struct unit_test_state *uts)
+{
+	const char *content = "   \t  \n";
+
+	env_set("bootargs", "stale");
+	cmdlinetxt_run(content, strlen(content));
+	ut_assertnull(env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_whitespace_only_line, 0);
+
+/*
+ * Leading whitespace on a non-empty first line is preserved --
+ * VideoCore does not trim.
+ */
+static int cmdlinetxt_test_leading_whitespace_preserved(
+					struct unit_test_state *uts)
+{
+	const char *content = "   root=/dev/nfs\n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("   root=/dev/nfs", env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_leading_whitespace_preserved, 0);
+
+/*
+ * Trailing whitespace before the LF is preserved too. Only the
+ * LF itself is excluded from the captured line.
+ */
+static int cmdlinetxt_test_trailing_whitespace_preserved(
+					struct unit_test_state *uts)
+{
+	const char *content = "root=/dev/nfs   \n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("root=/dev/nfs   ", env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_trailing_whitespace_preserved, 0);
+
+/*
+ * CRLF line ending: VideoCore does not treat '\r' specially, so
+ * the '\r' is included as the last char of bootargs (a known
+ * real-hardware quirk when users edit cmdline.txt on Windows).
+ */
+static int cmdlinetxt_test_crlf_preserves_cr(struct unit_test_state *uts)
+{
+	const char *content = "root=/dev/nfs\r\nignored\n";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str("root=/dev/nfs\r", env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_crlf_preserves_cr, 0);
+
+/*
+ * Exact reproduction of the cmdline.txt from issue #5 (252 bytes
+ * of NFS-root kernel args, no trailing LF). Verifies a realistic
+ * payload survives the parser unchanged.
+ */
+static int cmdlinetxt_test_issue5_cmdline(struct unit_test_state *uts)
+{
+	const char *content =
+		"root=/dev/nfs nfsroot=10.21.0.1:/srv/nfs/rpi/bookworm/root,"
+		"nfsvers=3 ro ip=dhcp rootwait consoleblank=0 "
+		"netconsole=@/,@10.21.0.1/ overlayroot=tmpfs "
+		"console=serial0,115200 systemd.log_level=debug "
+		"systemd.log_target=kmsg log_buf_len=1M printk.devkmsg=on";
+
+	cmdlinetxt_run(content, strlen(content));
+	ut_asserteq_str(content, env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_issue5_cmdline, 0);
+
+/*
+ * Empty buffer (size == 0) -> command wrapper clears bootargs
+ * directly without calling the parser. Exercise that path too.
+ */
+static int cmdlinetxt_test_zero_size(struct unit_test_state *uts)
+{
+	env_set("bootargs", "stale");
+	run_command("cmdlinetxt 1000 0", 0);
+	ut_assertnull(env_get("bootargs"));
+	return 0;
+}
+CMDLINETXT_TEST(cmdlinetxt_test_zero_size, 0);
