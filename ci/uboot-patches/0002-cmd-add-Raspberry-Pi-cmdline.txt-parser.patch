diff --git a/cmd/cmdlinetxt.c b/cmd/cmdlinetxt.c
new file mode 100644
index 00000000..ba625fbe
--- /dev/null
+++ b/cmd/cmdlinetxt.c
@@ -0,0 +1,58 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * cmdlinetxt - Raspberry Pi cmdline.txt parser command
+ *
+ * Reads a cmdline.txt buffer from memory and sets the bootargs
+ * environment variable using VideoCore GPU bootloader semantics.
+ * See include/rpi_cmdlinetxt.h and lib/rpi_cmdlinetxt.c for the
+ * parser rules.
+ */
+
+#include <command.h>
+#include <env.h>
+#include <mapmem.h>
+#include <rpi_cmdlinetxt.h>
+#include <vsprintf.h>
+
+static int do_cmdlinetxt(struct cmd_tbl *cmdtp, int flag,
+			 int argc, char *const argv[])
+{
+	unsigned long addr, size;
+	const char *buf;
+	int ret;
+
+	if (argc < 3)
+		return CMD_RET_USAGE;
+
+	addr = hextoul(argv[1], NULL);
+	size = hextoul(argv[2], NULL);
+
+	if (!size) {
+		/* Empty file -> delete bootargs, matching VideoCore's
+		 * fallback-to-defaults behaviour for empty cmdline.txt. */
+		ret = env_set("bootargs", NULL);
+		return ret == 0 ? CMD_RET_SUCCESS : CMD_RET_FAILURE;
+	}
+
+	buf = map_sysmem(addr, size);
+	if (!buf) {
+		printf("## Error: cannot map 0x%lx\n", addr);
+		return CMD_RET_FAILURE;
+	}
+
+	ret = rpi_cmdlinetxt_parse(buf, size);
+	unmap_sysmem(buf);
+
+	return ret == 0 ? CMD_RET_SUCCESS : CMD_RET_FAILURE;
+}
+
+U_BOOT_CMD(
+	cmdlinetxt, 3, 0, do_cmdlinetxt,
+	"Raspberry Pi cmdline.txt parser",
+	"<addr> <size> - parse cmdline.txt first line, set bootargs\n"
+	"\n"
+	"Matches VideoCore GPU bootloader behaviour: reads only the\n"
+	"first line (bytes before the first LF), passes it through\n"
+	"verbatim with no comment/whitespace processing, and deletes\n"
+	"bootargs if the first line is empty or whitespace-only."
+);
diff --git a/include/rpi_cmdlinetxt.h b/include/rpi_cmdlinetxt.h
new file mode 100644
index 00000000..08d360b5
--- /dev/null
+++ b/include/rpi_cmdlinetxt.h
@@ -0,0 +1,47 @@
+/* SPDX-License-Identifier: GPL-2.0+ */
+/*
+ * Raspberry Pi cmdline.txt parser
+ *
+ * Mirrors the semantics of the VideoCore GPU bootloader's cmdline.txt
+ * handling, so pxeboot firmware built on U-Boot produces the same
+ * kernel command line as real Raspberry Pi hardware.
+ *
+ * Observed VideoCore firmware behaviour (documented at
+ * https://www.raspberrypi.com/documentation/computers/configuration.html
+ * and confirmed by Raspberry Pi engineers on the official forums):
+ *
+ *   - Only the first line of cmdline.txt is used. Everything from the
+ *     first newline onwards is ignored (including any subsequent
+ *     "comment" lines -- they are not specially recognised, they just
+ *     happen to be skipped because they are on line 2+).
+ *   - The first line is passed through as-is. '#' is not a comment
+ *     marker, whitespace is not collapsed, and leading/trailing spaces
+ *     are preserved.
+ *   - If the first line is empty or contains only whitespace, the
+ *     firmware falls back to its built-in default command line.
+ *   - CRLF line endings are not specially handled; a trailing '\r' is
+ *     passed through as part of the last token (a common user bug on
+ *     real hardware, reproduced here to match behaviour).
+ */
+
+#ifndef __RPI_CMDLINETXT_H
+#define __RPI_CMDLINETXT_H
+
+#include <linux/types.h>
+
+/**
+ * rpi_cmdlinetxt_parse() - Parse cmdline.txt and set the bootargs env var
+ *
+ * Extracts the first line of @buf (up to but not including the first
+ * LF byte, or up to @size if no LF is present) and stores it in the
+ * "bootargs" environment variable. If the first line is empty or
+ * contains only whitespace characters, "bootargs" is deleted so that
+ * a caller-supplied default can take effect.
+ *
+ * @buf:  Read-only buffer containing cmdline.txt content
+ * @size: Size of buffer in bytes
+ * Return: 0 on success, -errno on failure
+ */
+int rpi_cmdlinetxt_parse(const char *buf, size_t size);
+
+#endif /* __RPI_CMDLINETXT_H */
