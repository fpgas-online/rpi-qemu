Subject: [PATCH 2/9] rpi: add config.txt model mapping tables

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 lib/rpi_cfgtxt.c | 99 ++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 99 insertions(+)
 create mode 100644 lib/rpi_cfgtxt.c

diff --git a/lib/rpi_cfgtxt.c b/lib/rpi_cfgtxt.c
new file mode 100644
index 00000000..8ff6eda5
--- /dev/null
+++ b/lib/rpi_cfgtxt.c
@@ -0,0 +1,99 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Raspberry Pi config.txt parser
+ *
+ * Parses VideoCore GPU bootloader config.txt format including
+ * conditional sections, key=value pairs, multi-value keys,
+ * and space-separated directives.
+ */
+
+#include <env.h>
+#include <rpi_cfgtxt.h>
+#include <string.h>
+
+/* --- Model name-to-enum mapping --- */
+
+struct model_name_entry {
+	const char *name;
+	enum rpi_board_model model;
+};
+
+static const struct model_name_entry model_names[] = {
+	{ "pi0",   RPI_MODEL_PI0 },
+	{ "pi0w",  RPI_MODEL_PI0 },
+	{ "pi02",  RPI_MODEL_PI02 },
+	{ "pi02w", RPI_MODEL_PI02 },
+	{ "pi1",   RPI_MODEL_PI1 },
+	{ "pi1a",  RPI_MODEL_PI1 },
+	{ "pi1b",  RPI_MODEL_PI1 },
+	{ "cm1",   RPI_MODEL_CM1 },
+	{ "pi2",   RPI_MODEL_PI2 },
+	{ "pi2b",  RPI_MODEL_PI2 },
+	{ "pi3",   RPI_MODEL_PI3 },
+	{ "pi3b",  RPI_MODEL_PI3 },
+	{ "pi3b+", RPI_MODEL_PI3 },
+	{ "pi3a+", RPI_MODEL_PI3 },
+	{ "cm3",   RPI_MODEL_CM3 },
+	{ "cm3+",  RPI_MODEL_CM3 },
+	{ "pi4",   RPI_MODEL_PI4 },
+	{ "pi4b",  RPI_MODEL_PI4 },
+	{ "pi400", RPI_MODEL_PI400 },
+	{ "cm4",   RPI_MODEL_CM4 },
+	{ "cm4s",  RPI_MODEL_CM4 },
+	{ "pi5",   RPI_MODEL_PI5 },
+	{ "pi500", RPI_MODEL_PI500 },
+	{ "cm5",   RPI_MODEL_CM5 },
+};
+
+int rpi_cfgtxt_model_from_str(const char *name)
+{
+	int i;
+
+	if (!name)
+		return -1;
+
+	for (i = 0; i < ARRAY_SIZE(model_names); i++) {
+		if (!strcmp(name, model_names[i].name))
+			return model_names[i].model;
+	}
+	return -1;
+}
+
+/* --- Model-to-section-filter mapping --- */
+
+static const char *filters_pi0[]   = { "pi0", NULL };
+static const char *filters_pi02[]  = { "pi0", "pi02", NULL };
+static const char *filters_pi1[]   = { "pi1", NULL };
+static const char *filters_cm1[]   = { "pi1", "cm1", NULL };
+static const char *filters_pi2[]   = { "pi2", NULL };
+static const char *filters_pi3[]   = { "pi3", NULL };
+static const char *filters_cm3[]   = { "pi3", "cm3", NULL };
+static const char *filters_pi4[]   = { "pi4", NULL };
+static const char *filters_pi400[] = { "pi4", "pi400", NULL };
+static const char *filters_cm4[]   = { "pi4", "cm4", NULL };
+static const char *filters_pi5[]   = { "pi5", NULL };
+static const char *filters_pi500[] = { "pi5", "pi500", NULL };
+static const char *filters_cm5[]   = { "pi5", "cm5", NULL };
+
+static const char * const *model_filters[RPI_MODEL_COUNT] = {
+	[RPI_MODEL_PI0]   = (const char * const *)filters_pi0,
+	[RPI_MODEL_PI02]  = (const char * const *)filters_pi02,
+	[RPI_MODEL_PI1]   = (const char * const *)filters_pi1,
+	[RPI_MODEL_CM1]   = (const char * const *)filters_cm1,
+	[RPI_MODEL_PI2]   = (const char * const *)filters_pi2,
+	[RPI_MODEL_PI3]   = (const char * const *)filters_pi3,
+	[RPI_MODEL_CM3]   = (const char * const *)filters_cm3,
+	[RPI_MODEL_PI4]   = (const char * const *)filters_pi4,
+	[RPI_MODEL_PI400] = (const char * const *)filters_pi400,
+	[RPI_MODEL_CM4]   = (const char * const *)filters_cm4,
+	[RPI_MODEL_PI5]   = (const char * const *)filters_pi5,
+	[RPI_MODEL_PI500] = (const char * const *)filters_pi500,
+	[RPI_MODEL_CM5]   = (const char * const *)filters_cm5,
+};
+
+const char * const *rpi_cfgtxt_model_filters(enum rpi_board_model model)
+{
+	if (model >= RPI_MODEL_COUNT)
+		return NULL;
+	return model_filters[model];
+}
-- 
