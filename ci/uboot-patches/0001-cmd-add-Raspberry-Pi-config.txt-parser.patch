Subject: [PATCH 8/9] test: add Python integration tests for cfgtxt command

---
 test/py/tests/test_cfgtxt.py | 40 ++++++++++++++++++++++++++++++++++++
 1 file changed, 40 insertions(+)
 create mode 100644 test/py/tests/test_cfgtxt.py

diff --git a/test/py/tests/test_cfgtxt.py b/test/py/tests/test_cfgtxt.py
new file mode 100644
index 00000000..12e1c323
--- /dev/null
+++ b/test/py/tests/test_cfgtxt.py
@@ -0,0 +1,40 @@
+# SPDX-License-Identifier: GPL-2.0+
+#
+# Tests for the cfgtxt (Raspberry Pi config.txt parser) command.
+
+import pytest
+
+
+@pytest.mark.buildconfigspec('cmd_cfgtxt')
+@pytest.mark.boardspec('sandbox')
+def test_cfgtxt_basic_import(ubman):
+    """Test basic config.txt parsing sets env vars."""
+    ram_base = 0x1000
+    cfg = b'kernel=kernel8.img\narm_64bit=1\n'
+    # Write config data to memory byte-by-byte
+    ubman.run_command('mw.b %x 0 100' % ram_base)
+    for i, b in enumerate(cfg):
+        ubman.run_command('mw.b %x %x' % (ram_base + i, b))
+    ubman.run_command('cfgtxt clear')
+    ubman.run_command('cfgtxt import %x %x pi4b' % (ram_base, len(cfg)))
+    response = ubman.run_command('printenv rpi_cfg_kernel')
+    assert 'kernel8.img' in response
+    response = ubman.run_command('printenv rpi_cfg_arm_64bit')
+    assert '1' in response
+
+
+@pytest.mark.buildconfigspec('cmd_cfgtxt')
+@pytest.mark.boardspec('sandbox')
+def test_cfgtxt_clear(ubman):
+    """Test cfgtxt clear removes all rpi_cfg_ vars."""
+    response = ubman.run_command('cfgtxt clear')
+    assert 'Removed' in response
+
+
+@pytest.mark.buildconfigspec('cmd_cfgtxt')
+@pytest.mark.boardspec('sandbox')
+def test_cfgtxt_error_zero_size(ubman):
+    """Test error on zero size."""
+    with ubman.disable_check('error_notification'):
+        response = ubman.run_command('cfgtxt import 1000 0 pi4b')
+    assert 'Error' in response
