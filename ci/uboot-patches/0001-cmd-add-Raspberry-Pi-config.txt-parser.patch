From 86335d5df90fba71e4a818451250fb33bd5c458e Mon Sep 17 00:00:00 2001
From: Tim 'mithro' Ansell <me@mith.ro>
Date: Sun, 12 Apr 2026 15:40:27 +0930
Subject: [PATCH 4/9] rpi: add config.txt directive handlers and parse loop

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 lib/rpi_cfgtxt.c | 195 +++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 195 insertions(+)

diff --git a/lib/rpi_cfgtxt.c b/lib/rpi_cfgtxt.c
index b60b9d26..552fe71d 100644
--- a/lib/rpi_cfgtxt.c
+++ b/lib/rpi_cfgtxt.c
@@ -8,8 +8,12 @@
  */
 
 #include <env.h>
+#include <env_internal.h>
+#include <linux/errno.h>
 #include <rpi_cfgtxt.h>
+#include <search.h>
 #include <string.h>
+#include <vsprintf.h>
 
 /* --- Model name-to-enum mapping --- */
 
@@ -319,3 +323,194 @@ static const char *copy_line(const char *pos, const char *end,
 		return eol + 1;
 	return eol;
 }
+
+/* --- Directive handlers --- */
+
+/*
+ * set_env_indexed() - Set a multi-value environment variable
+ *
+ * For keys like dtoverlay that can appear multiple times.
+ * Sets rpi_cfg_<key>_<N>=<value> and rpi_cfg_<key>_count=<N+1>.
+ */
+static void set_env_indexed(const char *prefix, int *counter,
+			    const char *value)
+{
+	char name[64];
+
+	snprintf(name, sizeof(name), "%s_%d", prefix, *counter);
+	env_set(name, value);
+	(*counter)++;
+	snprintf(name, sizeof(name), "%s_count", prefix);
+	env_set_ulong(name, *counter);
+}
+
+/*
+ * handle_directive() - Process a single accepted config.txt line
+ *
+ * Handles space-separated directives (initramfs, include),
+ * multi-value keys (dtoverlay, dtparam, gpio), and simple
+ * key=value pairs (last-wins).
+ */
+static void handle_directive(char *line, struct cfgtxt_state *state)
+{
+	char *eq;
+	char name[64];
+
+	/* Space-separated: initramfs <file> [<addr>] */
+	if (!strncmp(line, "initramfs ", 10)) {
+		char *file = line + 10;
+		char *addr;
+
+		/* Skip whitespace after "initramfs " */
+		while (*file == ' ' || *file == '\t')
+			file++;
+
+		if (!*file)
+			return;	/* "initramfs" alone -- no filename */
+
+		/* Find address argument */
+		addr = file;
+		while (*addr && *addr != ' ' && *addr != '\t')
+			addr++;
+
+		if (*addr) {
+			*addr = '\0';
+			addr++;
+			while (*addr == ' ' || *addr == '\t')
+				addr++;
+		}
+
+		env_set(RPI_CFGTXT_ENV_PREFIX "initramfs", file);
+
+		if (*addr)
+			env_set(RPI_CFGTXT_ENV_PREFIX "initramfs_addr", addr);
+		else
+			env_set(RPI_CFGTXT_ENV_PREFIX "initramfs_addr",
+				"followkernel");
+		return;
+	}
+
+	/* Space-separated: include <filename> */
+	if (!strncmp(line, "include ", 8)) {
+		char *file = line + 8;
+
+		while (*file == ' ' || *file == '\t')
+			file++;
+
+		if (!*file)
+			return;
+
+		if (state->opts->include_cb &&
+		    state->opts->include_depth < RPI_CFGTXT_MAX_INCLUDE_DEPTH)
+			state->opts->include_cb(file, state->opts->include_ctx);
+		return;
+	}
+
+	/* Key=value lines */
+	eq = strchr(line, '=');
+	if (!eq)
+		return;	/* No '=' and not a known directive: skip */
+
+	*eq = '\0';
+
+	/* Multi-value keys */
+	if (!strcmp(line, "dtoverlay")) {
+		set_env_indexed(RPI_CFGTXT_ENV_PREFIX "dtoverlay",
+				&state->dtoverlay_count, eq + 1);
+		return;
+	}
+	if (!strcmp(line, "dtparam")) {
+		set_env_indexed(RPI_CFGTXT_ENV_PREFIX "dtparam",
+				&state->dtparam_count, eq + 1);
+		return;
+	}
+	if (!strcmp(line, "gpio")) {
+		set_env_indexed(RPI_CFGTXT_ENV_PREFIX "gpio",
+				&state->gpio_count, eq + 1);
+		return;
+	}
+
+	/* Simple key=value (last-wins) */
+	snprintf(name, sizeof(name), "%s%s", RPI_CFGTXT_ENV_PREFIX, line);
+	env_set(name, eq + 1);
+}
+
+/* --- Main parse loop --- */
+
+int rpi_cfgtxt_parse(const char *buf, size_t size,
+		     const struct rpi_cfgtxt_opts *opts)
+{
+	struct cfgtxt_state state;
+	const char *pos = buf;
+	const char *end = buf + size;
+
+	if (!buf || !size || !opts)
+		return -EINVAL;
+
+	memset(&state, 0, sizeof(state));
+	state.opts = opts;
+	/* All filters start as FILTER_UNSET (== 0) */
+
+	while (pos < end) {
+		pos = copy_line(pos, end, &state);
+		if (!state.line_buf[0])
+			continue;	/* blank line */
+		if (state.line_buf[0] == '#')
+			continue;	/* comment */
+		if (state.line_buf[0] == '[') {
+			eval_section_header(state.line_buf, &state);
+			continue;
+		}
+		if (line_accepted(&state))
+			handle_directive(state.line_buf, &state);
+	}
+	return 0;
+}
+
+/* --- Clear function --- */
+
+/* Struct to collect rpi_cfg_* variable names for deletion */
+struct clear_ctx {
+	const char **names;
+	int count;
+	int capacity;
+};
+
+static int collect_rpi_cfg_var(struct env_entry *entry)
+{
+	/* This callback is called from hwalk_r but we need context.
+	 * Use a simpler approach: hmatch_r with prefix matching. */
+	return 0;
+}
+
+int rpi_cfgtxt_clear(void)
+{
+	struct env_entry *match;
+	int idx = 0;
+	int removed = 0;
+	const char *names[256];
+	int count = 0;
+	int i;
+
+	/*
+	 * Collect all rpi_cfg_* variable names first, then delete them.
+	 * We can't delete during iteration as it would invalidate the
+	 * hash table state.
+	 */
+	while (count < ARRAY_SIZE(names) &&
+	       (idx = hmatch_r(RPI_CFGTXT_ENV_PREFIX, idx, &match,
+			       &env_htab))) {
+		if (!strncmp(match->key, RPI_CFGTXT_ENV_PREFIX,
+			     strlen(RPI_CFGTXT_ENV_PREFIX))) {
+			names[count++] = match->key;
+		}
+	}
+
+	/* Now delete them */
+	for (i = 0; i < count; i++) {
+		if (env_set(names[i], NULL) == 0)
+			removed++;
+	}
+
+	return removed;
+}
