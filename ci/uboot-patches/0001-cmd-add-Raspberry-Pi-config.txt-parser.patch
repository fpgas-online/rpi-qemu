From db1cad5b94da9e0527f9bd9a0cca0fa0a7a2dc07 Mon Sep 17 00:00:00 2001
From: Tim 'mithro' Ansell <me@mith.ro>
Date: Sun, 12 Apr 2026 16:25:35 +0930
Subject: [PATCH 9/9] rpi: fix buffer size mismatch between write and clear
 paths

handle_directive() and set_env_indexed() used 520-byte name buffers,
but rpi_cfgtxt_clear() used 64-byte buffers to collect keys for
deletion. Long key names would be stored in env but couldn't be
cleared. Fix by using consistent 64-byte buffers everywhere and
rejecting keys too long for the buffer in handle_directive().

No real RPi config.txt key exceeds 55 characters (the effective
limit after the rpi_cfg_ prefix), so this only affects malformed input.
---
 lib/rpi_cfgtxt.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/lib/rpi_cfgtxt.c b/lib/rpi_cfgtxt.c
index 6a4cdfbb..79eca390 100644
--- a/lib/rpi_cfgtxt.c
+++ b/lib/rpi_cfgtxt.c
@@ -338,7 +338,7 @@ static const char *copy_line(const char *pos, const char *end,
 static void set_env_indexed(const char *prefix, int *counter,
 			    const char *value)
 {
-	char name[RPI_CFGTXT_MAX_LINE_LEN + sizeof(RPI_CFGTXT_ENV_PREFIX)];
+	char name[64];
 
 	snprintf(name, sizeof(name), "%s_%d", prefix, *counter);
 	env_set(name, value);
@@ -357,7 +357,7 @@ static void set_env_indexed(const char *prefix, int *counter,
 static void handle_directive(char *line, struct cfgtxt_state *state)
 {
 	char *eq;
-	char name[RPI_CFGTXT_MAX_LINE_LEN + sizeof(RPI_CFGTXT_ENV_PREFIX)];
+	char name[64];
 
 	/* Space-separated: initramfs <file> [<addr>] */
 	if (!strncmp(line, "initramfs ", 10)) {
@@ -421,6 +421,10 @@ static void handle_directive(char *line, struct cfgtxt_state *state)
 
 	*eq = '\0';
 
+	/* Reject keys too long for our name buffer (prefix + key < 64) */
+	if (strlen(line) > sizeof(name) - strlen(RPI_CFGTXT_ENV_PREFIX) - 1)
+		return;
+
 	/* Multi-value keys */
 	if (!strcmp(line, "dtoverlay")) {
 		set_env_indexed(RPI_CFGTXT_ENV_PREFIX "dtoverlay",
