From 54e066f0a7740c734c2d5329243af9783770e6a5 Mon Sep 17 00:00:00 2001
From: Tim 'mithro' Ansell <me@mith.ro>
Date: Sun, 12 Apr 2026 15:39:12 +0930
Subject: [PATCH 3/9] rpi: add config.txt line parser and filter state machine

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 lib/rpi_cfgtxt.c | 222 +++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 222 insertions(+)

diff --git a/lib/rpi_cfgtxt.c b/lib/rpi_cfgtxt.c
index 8ff6eda5..b60b9d26 100644
--- a/lib/rpi_cfgtxt.c
+++ b/lib/rpi_cfgtxt.c
@@ -97,3 +97,225 @@ const char * const *rpi_cfgtxt_model_filters(enum rpi_board_model model)
 		return NULL;
 	return model_filters[model];
 }
+
+/* --- Filter state machine --- */
+
+enum filter_state {
+	FILTER_UNSET,
+	FILTER_MATCH,
+	FILTER_NOMATCH,
+};
+
+struct cfgtxt_state {
+	enum filter_state model_filter;
+	enum filter_state serial_filter;
+	enum filter_state partition_filter;
+	enum filter_state tryboot_filter;
+	enum filter_state edid_filter;
+	enum filter_state gpio_filter;
+	bool none_active;
+
+	int dtoverlay_count;
+	int dtparam_count;
+	int gpio_count;
+
+	char line_buf[RPI_CFGTXT_MAX_LINE_LEN];
+	const struct rpi_cfgtxt_opts *opts;
+};
+
+/*
+ * line_accepted() - Check if current line passes all active filters
+ *
+ * A line is accepted when none_active is false and no filter is in
+ * FILTER_NOMATCH state.  FILTER_UNSET counts as passing.
+ */
+static bool line_accepted(const struct cfgtxt_state *state)
+{
+	if (state->none_active)
+		return false;
+	if (state->model_filter == FILTER_NOMATCH)
+		return false;
+	if (state->serial_filter == FILTER_NOMATCH)
+		return false;
+	if (state->partition_filter == FILTER_NOMATCH)
+		return false;
+	if (state->tryboot_filter == FILTER_NOMATCH)
+		return false;
+	if (state->edid_filter == FILTER_NOMATCH)
+		return false;
+	if (state->gpio_filter == FILTER_NOMATCH)
+		return false;
+	return true;
+}
+
+/*
+ * model_matches_section() - Check if a model matches a section filter name
+ *
+ * Looks up the model's filter list and checks if the given section
+ * name appears in it.
+ */
+static bool model_matches_section(enum rpi_board_model model,
+				  const char *section)
+{
+	const char * const *filters;
+	int i;
+
+	filters = rpi_cfgtxt_model_filters(model);
+	if (!filters)
+		return false;
+
+	for (i = 0; filters[i]; i++) {
+		if (!strcmp(filters[i], section))
+			return true;
+	}
+	return false;
+}
+
+/*
+ * eval_section_header() - Parse and evaluate a section header line
+ *
+ * Updates the appropriate filter in cfgtxt_state.
+ * Handles: [all], [none], [piN], [cmN], [serial=0x...],
+ *          [partition=N], [tryboot], [EDID=...], [gpio<N>=<0|1>]
+ */
+static void eval_section_header(const char *line, struct cfgtxt_state *state)
+{
+	const char *p = line + 1;	/* skip '[' */
+	char section[64];
+	char *end;
+	int len;
+
+	/* Find closing bracket */
+	end = strchr(p, ']');
+	if (!end)
+		return;
+
+	len = end - p;
+	if (len <= 0 || len >= sizeof(section))
+		return;
+
+	memcpy(section, p, len);
+	section[len] = '\0';
+
+	/* [all] - reset all filters */
+	if (!strcmp(section, "all")) {
+		state->model_filter = FILTER_UNSET;
+		state->serial_filter = FILTER_UNSET;
+		state->partition_filter = FILTER_UNSET;
+		state->tryboot_filter = FILTER_UNSET;
+		state->edid_filter = FILTER_UNSET;
+		state->gpio_filter = FILTER_UNSET;
+		state->none_active = false;
+		return;
+	}
+
+	/* [none] - block everything */
+	if (!strcmp(section, "none")) {
+		state->none_active = true;
+		return;
+	}
+
+	/* [tryboot] */
+	if (!strcmp(section, "tryboot")) {
+		state->tryboot_filter = state->opts->tryboot ?
+			FILTER_MATCH : FILTER_NOMATCH;
+		return;
+	}
+
+	/* [serial=0x...] */
+	if (!strncmp(section, "serial=", 7)) {
+		unsigned long long serial;
+
+		serial = simple_strtoull(section + 7, NULL, 16);
+		state->serial_filter = (serial == state->opts->serial) ?
+			FILTER_MATCH : FILTER_NOMATCH;
+		return;
+	}
+
+	/* [partition=N] */
+	if (!strncmp(section, "partition=", 10)) {
+		int part;
+
+		part = simple_strtoul(section + 10, NULL, 10);
+		state->partition_filter = (part == state->opts->boot_partition) ?
+			FILTER_MATCH : FILTER_NOMATCH;
+		return;
+	}
+
+	/* [EDID=...] - always NOMATCH (CONFIG_VIDEO disabled) */
+	if (!strncmp(section, "EDID=", 5)) {
+		state->edid_filter = FILTER_NOMATCH;
+		return;
+	}
+
+	/* [gpio<N>=<0|1>] */
+	if (!strncmp(section, "gpio", 4) && section[4] >= '0' &&
+	    section[4] <= '9') {
+		/*
+		 * GPIO filter: parse pin number and expected value.
+		 * Without DM GPIO available, always NOMATCH.
+		 */
+		state->gpio_filter = FILTER_NOMATCH;
+		return;
+	}
+
+	/* Model filter: [pi4], [cm3], [pi400], etc. */
+	if (model_matches_section(state->opts->model, section))
+		state->model_filter = FILTER_MATCH;
+	else
+		state->model_filter = FILTER_NOMATCH;
+}
+
+/*
+ * copy_line() - Copy one line from the input buffer into state->line_buf
+ *
+ * Handles LF and CRLF line endings.  Strips leading and trailing
+ * whitespace.  Truncates at RPI_CFGTXT_MAX_LINE_LEN - 1.
+ * Returns pointer to next line in the input buffer.
+ */
+static const char *copy_line(const char *pos, const char *end,
+			     struct cfgtxt_state *state)
+{
+	const char *eol;
+	const char *src;
+	int len, i;
+
+	/* Find end of line */
+	for (eol = pos; eol < end && *eol != '\n'; eol++)
+		;
+
+	/* Calculate raw line length (excluding newline) */
+	len = eol - pos;
+
+	/* Strip trailing \r for CRLF */
+	if (len > 0 && pos[len - 1] == '\r')
+		len--;
+
+	/* Skip leading whitespace */
+	src = pos;
+	while (src < pos + len && (*src == ' ' || *src == '\t'))
+		src++;
+	len -= (src - pos);
+
+	/* Truncate if needed */
+	if (len >= RPI_CFGTXT_MAX_LINE_LEN)
+		len = RPI_CFGTXT_MAX_LINE_LEN - 1;
+
+	/* Copy into line buffer */
+	if (len > 0)
+		memcpy(state->line_buf, src, len);
+	state->line_buf[len] = '\0';
+
+	/* Strip trailing whitespace */
+	for (i = len - 1; i >= 0; i--) {
+		if (state->line_buf[i] == ' ' || state->line_buf[i] == '\t')
+			state->line_buf[i] = '\0';
+		else
+			break;
+	}
+
+	/* Advance past newline */
+	if (eol < end)
+		return eol + 1;
+	return eol;
+}
-- 
