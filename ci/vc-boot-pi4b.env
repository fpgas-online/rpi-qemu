/* SPDX-License-Identifier: GPL-2.0+ */

/*
 * VideoCore GPU boot emulation for Raspberry Pi 4B (PXE/TFTP)
 *
 * This U-Boot environment script emulates the VideoCore GPU bootloader's
 * PXE TFTP probe sequence. It runs automatically via CONFIG_BOOTCOMMAND
 * and produces UART output that mimics the real Pi bootloader, so users
 * see VideoCore-style messages rather than U-Boot prompts.
 *
 * Loaded via CONFIG_ENV_SOURCE_FILE="pxeboot" which resolves to
 * board/raspberrypi/rpi/pxeboot.env at build time.
 */

/* --- Memory layout -------------------------------------------------- */
scratch_addr=0x02000000
kernel_addr_r=0x10000000
fdt_addr_r=0x0f000000
ramdisk_addr_r=0x12000000

/* --- Default serial number (overridable via QEMU fw_cfg) ------------ */
pi_serial=deadbeef

/* --- DHCP vendor class: PXEClient (option 60 + option 93) ----------- */
bootp_vci=PXEClient:Arch:00000:UNDI:002001
bootp_arch=0

/* --- Suppress default boot targets ---------------------------------- */
boot_targets=none

/* --- Helper: try to TFTP a file, print VideoCore-style status ------- *
 *  Usage: setenv _tf <filename>; run vc_tftp_probe                     *
 *  Sets _tf_ok=1 on success, _tf_ok=0 on failure.                     *
 *  Does NOT load to a useful address -- uses scratch for probing.      */
vc_tftp_probe=
    if tftpboot ${scratch_addr} ${_tf}; then
        setenv _tf_ok 1;
        echo "  Loading ${_tf} ... ${filesize} bytes";
    else;
        setenv _tf_ok 0;
        echo "  Loading ${_tf} ... not found";
    fi;

/* --- Helper: TFTP a file to a specific address ---------------------- *
 *  Usage: setenv _tf <filename>; setenv _tfa <addr>; run vc_tftp_load  *
 *  Sets _tf_ok=1 on success, _tf_ok=0 on failure.                     */
vc_tftp_load=
    if tftpboot ${_tfa} ${_tf}; then
        setenv _tf_ok 1;
        echo "  Loading ${_tf} ... ${filesize} bytes -> ${_tfa}";
    else;
        setenv _tf_ok 0;
        echo "  Loading ${_tf} ... not found";
    fi;

/* --- Phase 1: Read serial number from QEMU fw_cfg if available ------ */
vc_read_serial=
    setenv pi_serial deadbeef;
    echo "[vc-boot] Serial: ${pi_serial}";

/* --- Phase 2: DHCP -------------------------------------------------- */
vc_dhcp=
    echo "";
    echo "Raspberry Pi 4 Model B - PXE boot";
    echo "Board serial: ${pi_serial}";
    echo "DHCP: discovering...";
    setenv autoload no;
    if dhcp; then
        echo "DHCP: bound to ${ipaddr}";
        echo "TFTP server: ${serverip}";
    else;
        echo "DHCP: FAILED - no response";
        echo "ERROR: Cannot boot without network";
        reset;
    fi;

/* --- Phase 3: VideoCore TFTP probe sequence ------------------------- *
 *  Matches the real Pi 4B GPU bootloader file-by-file.                 *
 *  Files are serial-prefixed on a real Pi; we use the bare names       *
 *  since QEMU SLIRP TFTP serves from a flat directory.                 */
vc_probe_firmware=
    echo "";
    echo "--- VideoCore firmware probe ---";
    setenv _tf ${pi_serial}/start4.elf;       run vc_tftp_probe;
    setenv _tf ${pi_serial}/autoboot.txt;     run vc_tftp_probe;
    setenv _tf ${pi_serial}/config.txt;       run vc_tftp_probe;
    if test "${_tf_ok}" = "1"; then
        run vc_parse_config;
    fi;
    setenv _tf ${pi_serial}/recovery.elf;     run vc_tftp_probe;
    setenv _tf ${pi_serial}/start4.elf;       run vc_tftp_probe;
    setenv _tf ${pi_serial}/fixup4.dat;       run vc_tftp_probe;
    setenv _tf ${pi_serial}/recovery.elf;     run vc_tftp_probe;
    setenv _tf ${pi_serial}/config.txt;       run vc_tftp_probe;
    setenv _tf ${pi_serial}/dt-blob.bin;      run vc_tftp_probe;
    setenv _tf ${pi_serial}/recovery.elf;     run vc_tftp_probe;
    setenv _tf ${pi_serial}/config.txt;       run vc_tftp_probe;
    setenv _tf ${pi_serial}/bootcfg.txt;      run vc_tftp_probe;
    setenv _tf ${pi_serial}/cmdline.txt;      run vc_tftp_probe;
    if test "${_tf_ok}" = "1"; then
        run vc_parse_cmdline;
    fi;

/* --- Phase 4: Parse config.txt -------------------------------------- *
 *  Use selective env import: only "kernel" and "device_tree" variables  *
 *  are imported from the buffer. All other lines (comments, [pi4]      *
 *  sections, other keys) are safely ignored. No save/restore needed    *
 *  because selective import cannot clobber other env vars.             */
vc_parse_config=
    echo "  Parsing config.txt ...";
    setenv _cfg_kernel;
    setenv _cfg_dtb;
    if env import -t ${scratch_addr} ${filesize} kernel device_tree; then
        if test -n "${kernel}"; then
            setenv _cfg_kernel ${kernel};
            echo "  config.txt: kernel=${kernel}";
        fi;
        if test -n "${device_tree}"; then
            setenv _cfg_dtb ${device_tree};
            echo "  config.txt: device_tree=${device_tree}";
        fi;
    fi;
    setenv kernel;
    setenv device_tree;

/* --- Phase 5: Parse cmdline.txt ------------------------------------- *
 *  Try to import bootargs from cmdline.txt. The TFTP server should     *
 *  provide this in "bootargs=..." format for env import -t to work.    *
 *  If the file is raw kernel args (no key=value), import silently      *
 *  fails and we fall back to defaults in vc_setup_bootargs.            */
vc_parse_cmdline=
    echo "  Parsing cmdline.txt ...";
    setenv _save_bootcmd_cl ${bootcmd};
    env import -t ${scratch_addr} ${filesize} bootargs;
    setenv bootcmd ${_save_bootcmd_cl};
    setenv _save_bootcmd_cl;

/* --- Phase 6: Recovery image probes (probe only, not loaded) -------- */
vc_probe_recovery=
    echo "";
    echo "--- Recovery image probe ---";
    for r in recovery8.img recovery8-32.img recovery7.img recovery.img; do
        setenv _tf ${pi_serial}/${r};
        run vc_tftp_probe;
    done;

/* --- Phase 7: Kernel probe ------------------------------------------ *
 *  Try config.txt kernel= first (if set), then standard Pi 4B         *
 *  probe sequence. First successful TFTP loads to kernel_addr_r.       */
vc_probe_kernel=
    echo "";
    echo "--- Kernel probe ---";
    setenv _kern_ok 0;
    if test -n "${_cfg_kernel}"; then
        echo "  Trying config.txt kernel: ${_cfg_kernel}";
        setenv _tf ${pi_serial}/${_cfg_kernel};
        setenv _tfa ${kernel_addr_r};
        run vc_tftp_load;
        if test "${_tf_ok}" = "1"; then
            setenv _kern_ok 1;
        fi;
    fi;
    if test "${_kern_ok}" = "0"; then
        for k in kernel8.img kernel8-32.img kernel7l.img kernel7.img kernel.img; do
            if test "${_kern_ok}" = "0"; then
                setenv _tf ${pi_serial}/${k};
                setenv _tfa ${kernel_addr_r};
                run vc_tftp_load;
                if test "${_tf_ok}" = "1"; then
                    setenv _kern_ok 1;
                fi;
            fi;
        done;
    fi;

/* --- Phase 8: Armstub probe (probe only, not loaded) ---------------- */
vc_probe_armstub=
    echo "";
    echo "--- ARM stub probe ---";
    for a in armstub8.bin armstub8-32.bin armstub7.bin armstub.bin; do
        setenv _tf ${pi_serial}/${a};
        run vc_tftp_probe;
    done;

/* --- Phase 9: DTB probe --------------------------------------------- *
 *  Try config.txt device_tree= first, then bcm2711-rpi-4-b.dtb.       *
 *  First successful TFTP loads to fdt_addr_r.                          */
vc_probe_dtb=
    echo "";
    echo "--- Device tree probe ---";
    setenv _dtb_ok 0;
    if test -n "${_cfg_dtb}"; then
        echo "  Trying config.txt device_tree: ${_cfg_dtb}";
        setenv _tf ${pi_serial}/${_cfg_dtb};
        setenv _tfa ${fdt_addr_r};
        run vc_tftp_load;
        if test "${_tf_ok}" = "1"; then
            setenv _dtb_ok 1;
        fi;
    fi;
    if test "${_dtb_ok}" = "0"; then
        setenv _tf ${pi_serial}/bcm2711-rpi-4-b.dtb;
        setenv _tfa ${fdt_addr_r};
        run vc_tftp_load;
        if test "${_tf_ok}" = "1"; then
            setenv _dtb_ok 1;
        fi;
    fi;

/* --- Phase 9b: Fix DTB serial aliases ------------------------------- *
 *  The RPi firmware DTB swaps serial0/serial1 aliases because the      *
 *  PL011 is used for Bluetooth on real hardware.  QEMU has no          *
 *  Bluetooth and the PL011 is connected to the QEMU serial port,      *
 *  so restore serial0→PL011 to make console=ttyAMA0 work.             */
vc_fix_serial_aliases=
    if test "${_dtb_ok}" = "1"; then
        fdt addr ${fdt_addr_r};
        fdt set /aliases serial0 /soc/serial@7e201000;
        fdt set /aliases serial1 /soc/serial@7e215040;
    fi;

/* --- Phase 10: Set up bootargs -------------------------------------- *
 *  If bootargs is empty, set the QEMU serial console defaults.         *
 *  If bootargs exists (from cmdline.txt), append earlycon+console      *
 *  unconditionally -- duplicate console= args are harmless and the     *
 *  last one wins in Linux.                                             */
vc_setup_bootargs=
    if test -z "${bootargs}"; then
        setenv bootargs earlycon=pl011,mmio32,0xfe201000 console=ttyAMA0;
    else;
        setenv bootargs ${bootargs} earlycon=pl011,mmio32,0xfe201000 console=ttyAMA0;
    fi;
    echo "  bootargs: ${bootargs}";

/* --- Phase 11: Initrd probe ----------------------------------------- *
 *  Try to load an initrd/initramfs. Real VideoCore uses initramfs=      *
 *  from config.txt. We also try common names.                           */
vc_probe_initrd=
    echo "";
    echo "--- Initrd probe ---";
    setenv _initrd_ok 0;
    setenv _initrd_arg -;
    for i in initrd.gz initrd.img initramfs.gz initramfs.cpio.gz; do
        if test "${_initrd_ok}" = "0"; then
            setenv _tf ${pi_serial}/${i};
            setenv _tfa ${ramdisk_addr_r};
            run vc_tftp_load;
            if test "${_tf_ok}" = "1"; then
                setenv _initrd_ok 1;
                setenv _initrd_arg ${ramdisk_addr_r}:${filesize};
            fi;
        fi;
    done;

/* --- Phase 12: Boot! ------------------------------------------------ */
vc_boot_kernel=
    echo "";
    if test "${_kern_ok}" = "0"; then
        echo "ERROR: No kernel image found";
        echo "  Tried: kernel8.img kernel8-32.img kernel7l.img kernel7.img kernel.img";
        if test -n "${_cfg_kernel}"; then
            echo "  Also tried config.txt kernel=${_cfg_kernel}";
        fi;
        echo "Resetting in 5 seconds...";
        sleep 5;
        reset;
    fi;
    if test "${_dtb_ok}" = "0"; then
        echo "ERROR: No device tree found";
        echo "  Tried: bcm2711-rpi-4-b.dtb";
        if test -n "${_cfg_dtb}"; then
            echo "  Also tried config.txt device_tree=${_cfg_dtb}";
        fi;
        echo "Resetting in 5 seconds...";
        sleep 5;
        reset;
    fi;
    echo "Starting kernel ...";
    echo "  kernel:  ${kernel_addr_r}";
    echo "  initrd:  ${_initrd_arg}";
    echo "  dtb:     ${fdt_addr_r}";
    echo "  bootargs: ${bootargs}";
    echo "";
    booti ${kernel_addr_r} ${_initrd_arg} ${fdt_addr_r};
    echo "";
    echo "ERROR: booti failed";
    echo "Resetting in 5 seconds...";
    sleep 5;
    reset;

/* --- Main entry point: called by CONFIG_BOOTCOMMAND="run vc_boot" --- */
vc_boot=
    echo "";
    echo "Raspberry Pi Bootloader";
    echo "RPIBOOT: build-date Apr  7 2025 kernel ~00000000";
    echo "";
    echo "PE: kernel-boot";
    echo "";
    run vc_read_serial;
    run vc_dhcp;
    run vc_probe_firmware;
    run vc_probe_recovery;
    run vc_probe_kernel;
    run vc_probe_armstub;
    run vc_probe_dtb;
    run vc_fix_serial_aliases;
    run vc_probe_initrd;
    run vc_setup_bootargs;
    run vc_boot_kernel;
